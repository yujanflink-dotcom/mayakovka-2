# Database URL (local development only — SQLite file)
DATABASE_URL="file:./dev.db"

# Turso (produccion serverless en Vercel)
# Crear cuenta gratis en https://turso.tech, crear una DB y copiar los valores:
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Secret for cron job authentication
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# Deployed app URL (for GitHub Actions cron)
# APP_URL=https://your-app.vercel.app
